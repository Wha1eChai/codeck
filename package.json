{
  "private": true,
  "name": "@codeck/workspace",
  "author": "Wha1eChai <whaleora@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wha1eChai/codeck.git"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:config": "pnpm --filter @codeck/config run test",
    "test:sessions": "pnpm --filter @codeck/sessions run test",
    "test:provider": "pnpm --filter @codeck/provider run test",
    "test:agent-core": "pnpm --filter @codeck/agent-core run test",
    "dev": "pnpm --filter codeck run dev"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild"
    ],
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron"
    ]
  }
}
