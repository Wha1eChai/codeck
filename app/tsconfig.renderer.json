{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "paths": {
      "@common/*": ["./src/common/*"],
      "@renderer/*": ["./src/renderer/*"]
    }
  },
  "include": ["src/renderer/**/*", "src/common/**/*"],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/*.test.*"
  ]
}
