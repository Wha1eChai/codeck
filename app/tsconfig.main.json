{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "paths": {
      "@common/*": ["./src/common/*"],
      "@codeck/config": ["../packages/config/src/index.ts"],
      "@codeck/provider": ["../packages/provider/src/index.ts"],
      "@codeck/agent-core": ["../packages/agent-core/src/index.ts"]
    }
  },
  "include": ["src/main/**/*", "src/common/**/*"],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/__integration__/**",
    "src/**/*.test.*"
  ]
}
